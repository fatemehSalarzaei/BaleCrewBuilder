# {{ project.name }} production environment example
# Copy to deploy/.env and replace every placeholder before deploying.

POSTGRES_DB={{ project.slug | replace("-", "_") }}
POSTGRES_USER={{ project.slug | replace("-", "_") }}_app
POSTGRES_PASSWORD=replace-with-strong-postgres-password

DATABASE_URL=postgresql+asyncpg://{{ project.slug | replace("-", "_") }}_app:replace-with-strong-postgres-password@postgres:5432/{{ project.slug | replace("-", "_") }}
REDIS_URL=redis://redis:6379/0
SECRET_KEY=replace-with-long-random-secret-key

BACKEND_PORT=8000
FRONTEND_PORT=8080
BACKEND_BASE_URL=http://backend:8000
BACKEND_SERVICE_TOKEN=replace-with-random-service-token
VITE_API_BASE_URL=http://localhost:8000

{% for bot in bots %}
{{ bot.token_env }}=replace-with-{{ bot.key | replace("_", "-") }}-token
{{ bot.key | upper }}_WEBHOOK_URL=https://example.com{{ bot.webhook_path }}
{{ bot.key | upper }}_WEBHOOK_SECRET=replace-with-{{ bot.key | replace("_", "-") }}-webhook-secret
{% endfor %}
{% if has_celery_worker %}

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
{% endif %}
