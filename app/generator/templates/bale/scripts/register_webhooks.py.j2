"""Register Bale webhooks for the generated project's configured bots.

Usage:
    python -m bale.scripts.register_webhooks --dry-run
    python -m bale.scripts.register_webhooks

Environment:
    PUBLIC_BASE_URL must be the public HTTPS origin of the backend.
{% for bot in bots %}
    {{ bot.token_env }} must contain the {{ bot.title }} token.
{% if security.bot_webhook_secret %}
    {{ bot.token_env }}_WEBHOOK_SECRET must contain the webhook secret for {{ bot.key }}.
{% endif %}
{% endfor %}

This script never prints bot token values.
"""
from __future__ import annotations

import argparse
import asyncio
import os
from collections.abc import Callable
from dataclasses import dataclass

from bale.shared.client import (
{% for bot in bots %}
    make_{{ bot.key }}_client,
{% endfor %}
)


PUBLIC_BASE_URL_ENV = "PUBLIC_BASE_URL"


@dataclass(frozen=True)
class BotWebhookConfig:
    key: str
    title: str
    token_env: str
    webhook_path: str
    client_factory: Callable[[], object]


BOT_WEBHOOK_CONFIGS: tuple[BotWebhookConfig, ...] = (
{% for bot in bots %}
    BotWebhookConfig(
        key="{{ bot.key }}",
        title="{{ bot.title }}",
        token_env="{{ bot.token_env }}",
        webhook_path="{{ bot.webhook_path }}",
        client_factory=make_{{ bot.key }}_client,
    ),
{% endfor %}
)


def _clean_base_url(public_base_url: str) -> str:
    cleaned = public_base_url.strip().rstrip("/")
    if not cleaned:
        raise RuntimeError(f"{PUBLIC_BASE_URL_ENV} is required")
    if not cleaned.startswith(("https://", "http://")):
        raise RuntimeError(f"{PUBLIC_BASE_URL_ENV} must include http:// or https://")
    return cleaned


def get_public_base_url() -> str:
    return _clean_base_url(os.environ.get(PUBLIC_BASE_URL_ENV, ""))


def build_webhook_url(public_base_url: str, webhook_path: str) -> str:
    base = _clean_base_url(public_base_url)
    path = webhook_path if webhook_path.startswith("/") else f"/{webhook_path}"
    return f"{base}{path}"


def _require_env(name: str) -> None:
    if not os.environ.get(name):
        raise RuntimeError(f"Required environment variable is missing: {name}")


def _secret_env(config: BotWebhookConfig) -> str:
    return f"{config.token_env}_WEBHOOK_SECRET"


async def register_one(
    config: BotWebhookConfig,
    *,
    public_base_url: str,
    dry_run: bool,
) -> None:
    url = build_webhook_url(public_base_url, config.webhook_path)
    secret_env = _secret_env(config)
    secret_configured = bool(os.environ.get(secret_env))

    if dry_run:
        print(
            f"[dry-run] register {config.key}: url={url} "
            f"token_env={config.token_env} webhook_secret_configured={secret_configured}"
        )
        return

    _require_env(config.token_env)
{% if security.bot_webhook_secret %}
    _require_env(secret_env)
{% endif %}
    client = config.client_factory()
    result = await client.set_webhook(
        url,
        secret_token=os.environ.get(secret_env),
    )
    ok = bool(isinstance(result, dict) and result.get("ok", True))
    print(f"registered {config.key}: ok={ok} url={url}")


async def register_all(*, dry_run: bool = False) -> None:
    public_base_url = get_public_base_url()
    for config in BOT_WEBHOOK_CONFIGS:
        await register_one(config, public_base_url=public_base_url, dry_run=dry_run)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Register generated Bale bot webhooks")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print webhook URLs without calling the Bale API",
    )
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    asyncio.run(register_all(dry_run=args.dry_run))


if __name__ == "__main__":
    main()
