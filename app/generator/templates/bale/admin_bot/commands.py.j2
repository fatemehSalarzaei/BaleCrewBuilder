"""{{ bot.title }} — Admin Bot command dispatcher.

Commands defined in Blueprint:
{% for cmd in bot.commands %}
  {{ cmd.command }} → {{ cmd.handler }} (roles: {{ cmd.allowed_roles | join(', ') or 'admin' }})
{% endfor %}

All commands require admin role verification via the backend RBAC service.
Sensitive callbacks are audited per Blueprint security_policy (R10).
Business logic belongs in backend services (R7).
"""
from typing import Any

from bale.shared.backend_client import BackendClient, make_backend_client
from bale.shared.client import make_{{ bot.key }}_client

_BOT_KEY = "{{ bot.key }}"
_BOT_AUDIENCE = "{{ bot.audience }}"
_BACKEND_UNAVAILABLE_MESSAGE = (
    "This admin action is not available yet. Please try again later."
)
_UNAUTHORIZED_MESSAGE = "You are not authorized to use this bot."
_FORBIDDEN_MESSAGE = "You are not authorized to perform this action."


def _chat_id(update: dict[str, Any]) -> str | int | None:
    message = update.get("message") or {}
    chat = message.get("chat") or {}
    return chat.get("id")


async def _send_text(update: dict[str, Any], text: str) -> None:
    chat_id = _chat_id(update)
    if chat_id is None:
        return
    await make_{{ bot.key }}_client().send_message(chat_id, text)

async def _verify_admin_role(update: dict[str, Any]) -> bool:
    """Verify that the sender has admin role via backend RBAC.

    Never trust the Bale sender ID alone. The backend performs the lookup.
    Fail closed when the backend lookup is unavailable.
    """
    return await make_backend_client().verify_admin_role(update, _BOT_KEY)


async def _check_permission(update: dict[str, Any], permission_key: str) -> bool:
    """Check a fine-grained permission for the sender via backend RBAC.

    Called per-handler in addition to the dispatch-level _verify_admin_role() check.
    The backend RBAC service owns the permission decision.
    """
    return await make_backend_client().check_permission(update, _BOT_KEY, permission_key)


async def _call_command_action(
    update: dict[str, Any],
    *,
    command: str,
    handler: str,
    backend_client: BackendClient | None = None,
) -> None:
    client = backend_client or make_backend_client()
    result = await client.call_service_action(
        handler,
        update,
        bot_key=_BOT_KEY,
        command=command,
        audience=_BOT_AUDIENCE,
    )
    message = _BACKEND_UNAVAILABLE_MESSAGE
    if result:
        message = str(result.get("message") or result.get("detail") or message)
    await _send_text(update, message)


async def dispatch(update: dict[str, Any]) -> None:
    """Route an admin update to the appropriate command handler.

    Rejects non-admin senders before any command is dispatched.
    """
    if not await _verify_admin_role(update):
        await _send_text(update, _UNAUTHORIZED_MESSAGE)
        return
    message = update.get("message") or {}
    text: str = message.get("text") or ""
{% for cmd in bot.commands %}
    if text.startswith("{{ cmd.command }}"):
        await {{ cmd.handler }}(update)
        return
{% endfor %}
    # No matching command — ignore silently
{% for cmd in bot.commands %}


async def {{ cmd.handler }}(update: dict[str, Any]) -> None:
    """{{ cmd.command }} admin handler. Allowed roles: {{ cmd.allowed_roles | join(', ') or 'admin' }}.

    Delegates project-specific business logic to the backend service layer.
    """
    if not await _check_permission(update, "{{ cmd.handler }}"):
        await _send_text(update, _FORBIDDEN_MESSAGE)
        return
{% if bot.security_policy.audit_sensitive_callbacks %}
    await make_backend_client().log_bot_audit(
        "{{ cmd.handler }}",
        update,
        bot_key=_BOT_KEY,
        command="{{ cmd.command }}",
    )
{% endif %}
    await _call_command_action(
        update,
        command="{{ cmd.command }}",
        handler="{{ cmd.handler }}",
    )
{% endfor %}
