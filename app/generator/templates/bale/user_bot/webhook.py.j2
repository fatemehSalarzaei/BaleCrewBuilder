"""{{ bot.title }} — User Bot webhook handler.

Blueprint metadata:
  key:                      {{ bot.key }}
  audience:                 {{ bot.audience }}
  webhook_path:             {{ bot.webhook_path }}
  token_env:                {{ bot.token_env }}
  require_registered_user:  {{ bot.security_policy.require_registered_user }}

Only registered users can interact with this bot.
All registration checks happen inside the command dispatcher (commands.py).
"""
import os
from typing import Any

from fastapi import APIRouter, Header, HTTPException, Request, status

from bale.shared.idempotency import extract_update_id, is_duplicate_update, mark_update_processed
from bale.shared.webhook import WebhookVerificationError, parse_update, verify_webhook_signature
from bale.{{ bot.key }}.commands import dispatch

router = APIRouter()

_WEBHOOK_SECRET_ENV = "{{ bot.token_env }}_WEBHOOK_SECRET"


@router.post("{{ bot.webhook_path }}")
async def receive_{{ bot.key }}_update(
    request: Request,
{% if security.bot_webhook_secret %}
    x_bale_signature: str | None = Header(default=None, alias="X-Bale-Signature"),
{% endif %}
) -> dict[str, Any]:
{% if security.bot_webhook_secret %}
    _secret = os.environ.get(_WEBHOOK_SECRET_ENV, "")
    if not _secret:
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Webhook secret not configured ({_WEBHOOK_SECRET_ENV})",
        )
    if x_bale_signature is None:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Missing X-Bale-Signature header",
        )
    raw_body = await request.body()
    try:
        verify_webhook_signature(_secret, raw_body, x_bale_signature)
    except WebhookVerificationError:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Invalid webhook signature",
        )
{% endif %}
    raw_update = await request.json()
    update = parse_update(raw_update)

    _update_id = extract_update_id(update)
    if _update_id is not None and await is_duplicate_update(_update_id, "{{ bot.key }}"):
        return {"ok": True}

    await dispatch(update)

    if _update_id is not None:
        await mark_update_processed(_update_id, "{{ bot.key }}")

    return {"ok": True}
