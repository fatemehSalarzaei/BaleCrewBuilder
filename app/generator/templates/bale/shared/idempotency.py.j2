"""Shared idempotency helpers — prevent duplicate Bale update processing.

Uses the `processed_updates` table (a required core entity) to ensure each
Bale update_id is processed at most once per bot, even if the Bale platform
delivers the same webhook payload more than once.

Flow (enforced in each bot's webhook.py):
  1. Extract update_id from the incoming update.
  2. Call is_duplicate_update() — return {"ok": True} immediately if True.
  3. Call dispatch() to process the update.
  4. Call mark_update_processed() after successful dispatch.

Table: processed_updates
  update_id    (string PK)
  bot_key      (string)
  processed_at (datetime)
"""
from typing import Any


def extract_update_id(update: dict[str, Any]) -> str | None:
    """Extract the unique update ID from a parsed Bale update dict.

    Returns the update_id as a string when present, None otherwise.
    Bale delivers update_id as an integer; convert to string for consistent storage.
    """
    raw_id = update.get("update_id")
    if raw_id is None:
        return None
    return str(raw_id)


