{% if entity_has_pk and entity_pk_py_type == "UUID" %}
from uuid import UUID
{% endif %}
{% if entity_has_pk %}
from fastapi import APIRouter, Depends, HTTPException, status
{% else %}
from fastapi import APIRouter, Depends, status
{% endif %}
from sqlalchemy.ext.asyncio import AsyncSession

from app.api.deps import get_db
{% if entity_has_pk %}
from app.schemas.{{ entity.name }} import {{ entity_class_name }}Create, {{ entity_class_name }}Read, {{ entity_class_name }}Update
{% else %}
from app.schemas.{{ entity.name }} import {{ entity_class_name }}Create, {{ entity_class_name }}Read
{% endif %}
from app.services.{{ entity.name }}_service import {{ entity_class_name }}Service

router = APIRouter()


@router.get("/", response_model=list[{{ entity_class_name }}Read])
async def list_{{ entity.name }}(db: AsyncSession = Depends(get_db)) -> list[{{ entity_class_name }}Read]:
    return await {{ entity_class_name }}Service(db).list()

{% if entity_has_pk %}


@router.get("/{record_id}", response_model={{ entity_class_name }}Read)
async def get_{{ entity.name }}(record_id: {{ entity_pk_py_type }}, db: AsyncSession = Depends(get_db)) -> {{ entity_class_name }}Read:
    row = await {{ entity_class_name }}Service(db).get(record_id)
    if row is None:
        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="{{ entity_class_name }} not found")
    return row

{% endif %}


@router.post("/", response_model={{ entity_class_name }}Read, status_code=status.HTTP_201_CREATED)
async def create_{{ entity.name }}(data: {{ entity_class_name }}Create, db: AsyncSession = Depends(get_db)) -> {{ entity_class_name }}Read:
    return await {{ entity_class_name }}Service(db).create(data)

{% if entity_has_pk %}


@router.put("/{record_id}", response_model={{ entity_class_name }}Read)
async def update_{{ entity.name }}(record_id: {{ entity_pk_py_type }}, data: {{ entity_class_name }}Update, db: AsyncSession = Depends(get_db)) -> {{ entity_class_name }}Read:
    row = await {{ entity_class_name }}Service(db).update(record_id, data)
    if row is None:
        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="{{ entity_class_name }} not found")
    return row


@router.delete("/{record_id}", status_code=status.HTTP_204_NO_CONTENT)
async def delete_{{ entity.name }}(record_id: {{ entity_pk_py_type }}, db: AsyncSession = Depends(get_db)) -> None:
    if not await {{ entity_class_name }}Service(db).delete(record_id):
        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="{{ entity_class_name }} not found")
{% endif %}
