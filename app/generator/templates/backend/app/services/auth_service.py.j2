from typing import Any

from sqlalchemy.ext.asyncio import AsyncSession

from app.core.security import create_access_token, verify_password
{% if miniapp.enabled %}
from app.services.miniapp_auth_service import MiniAppAuthService
{% endif %}


class AuthService:
    # Roles defined in Blueprint: {{ roles | map(attribute='key') | join(', ') }}

    def __init__(self, db: AsyncSession) -> None:
        self.db = db

    async def authenticate(
        self, username: str, password: str
    ) -> dict[str, Any] | None:
        """Authenticate a user once project-specific user lookup is implemented.

        Password hashing and JWT primitives are available in app.core.security.
        This method intentionally returns None until the generated project's
        user model/query is wired here; it must not hard-code users or accept
        credentials without a backend lookup.
        """
        # TODO: load user from DB by username, then:
        # if not verify_password(password, user.hashed_password): return None
        # return {"sub": str(user.id), "roles": [role.key for role in user.roles]}
        _ = (username, password, verify_password)
        return None

    async def login(self, username: str, password: str) -> str:
        payload = await self.authenticate(username, password)
        if payload is None:
            raise ValueError("Invalid credentials")
        return create_access_token(payload)
{% if miniapp.enabled %}

    async def verify_miniapp_token(self, init_data: str) -> dict[str, Any]:
        """Verify raw Bale Mini App initData on the backend.

        Auth endpoint defined in Blueprint: {{ miniapp.auth_endpoint }}.
        The verifier rejects unsafe or stale initData and fails closed until the
        exact Bale Mini App HMAC derivation contract is confirmed.
        """
        verifier = MiniAppAuthService()
        return verifier.verify_init_data(init_data)
{% endif %}
