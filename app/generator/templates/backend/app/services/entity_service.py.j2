from uuid import UUID

{% endif %}
from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

from app.models.{{ entity.name }} import {{ entity_class_name }}
from app.schemas.{{ entity.name }} import (
    {{ entity_class_name }}Create,
    {{ entity_class_name }}Read,
{% if entity_has_pk %}
    {{ entity_class_name }}Update,
{% endif %}
)


class {{ entity_class_name }}Service:
    def __init__(self, db: AsyncSession) -> None:
        self._db = db

    async def list(self) -> list[{{ entity_class_name }}Read]:
        result = await self._db.execute(select({{ entity_class_name }}))
        return [{{ entity_class_name }}Read.model_validate(row) for row in result.scalars().all()]

{% if entity_has_pk %}
    async def get(self, record_id: {{ entity_pk_py_type }}) -> {{ entity_class_name }}Read | None:
        row = await self._db.get({{ entity_class_name }}, record_id)
        return {{ entity_class_name }}Read.model_validate(row) if row else None

{% endif %}
    async def create(self, data: {{ entity_class_name }}Create) -> {{ entity_class_name }}Read:
        row = {{ entity_class_name }}(**data.model_dump(exclude_unset=True))
        self._db.add(row)
        await self._db.commit()
        await self._db.refresh(row)
        return {{ entity_class_name }}Read.model_validate(row)

{% if entity_has_pk %}
    async def update(self, record_id: {{ entity_pk_py_type }}, data: {{ entity_class_name }}Update) -> {{ entity_class_name }}Read | None:
        row = await self._db.get({{ entity_class_name }}, record_id)
        if row is None:
            return None
        for key, value in data.model_dump(exclude_unset=True).items():
            setattr(row, key, value)
        await self._db.commit()
        await self._db.refresh(row)
        return {{ entity_class_name }}Read.model_validate(row)

    async def delete(self, record_id: {{ entity_pk_py_type }}) -> bool:
        row = await self._db.get({{ entity_class_name }}, record_id)
        if row is None:
            return False
        await self._db.delete(row)
        await self._db.commit()
        return True
{% endif %}
