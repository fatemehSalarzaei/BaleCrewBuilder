# Builder Platform — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

APP_ENV=development
APP_DEBUG=false
SECRET_KEY=change-me-to-a-random-secret

# PostgreSQL — matches docker-compose defaults for local dev
DATABASE_URL=postgresql+asyncpg://builder:builder@localhost:5432/builder

# Redis — matches docker-compose defaults for local dev
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
